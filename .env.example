# ── LLM Provider (choose one) ──────────────────────────────────────────────────
# Option A: Groq (fast & free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Option B: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# ── Model selection ────────────────────────────────────────────────────────────
LLM_PROVIDER=groq                          # groq | openai
# GROQ_MODEL=llama-3.3-70b-versatile                 # (Optional) Overrides centralized config
OPENAI_MODEL=gpt-4o-mini

# ── Embedding model ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2           # HuggingFace sentence-transformer model

# ── App settings ───────────────────────────────────────────────────────────────
APP_ENV=development                        # development | production
MAX_RESUME_LENGTH=5000                     # character limit for resume text
